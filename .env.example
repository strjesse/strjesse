# =====================================================================
# Copy these into Vercel → Project → Settings → Environment Variables.
# (For local testing with `vercel dev`, copy this file to `.env` and fill
#  it in — `.env` is gitignored and must NEVER be committed.)
# =====================================================================

# ---- Stripe (use TEST keys while building: they start with sk_test_) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price of the session, in the smallest currency unit (cents). 25000 = $250.00
PRICE_CENTS=25000
CURRENCY=usd

# ---- Session timing ----
SESSION_MINUTES=90
# Timezone the booking slots are expressed in (Jesse's working tz):
BUSINESS_TIMEZONE=America/New_York
# Days off, 0=Sun..6=Sat (comma separated). Default: Sundays closed.
CLOSED_DOW=0

# ---- Google Calendar (service account) ----
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key from the JSON key file. Keep the literal \n sequences;
# in Vercel paste the real multi-line key OR keep \n — the code handles \n.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# The calendar to book into — your Workspace user email:
GOOGLE_CALENDAR_ID=jesse@yourdomain.com

# ---- Google Workspace: domain-wide delegation (enables auto Meet links) ----
# The Workspace user the backend acts as. Set this and each booking gets a
# fresh Google Meet link automatically. Leave blank on a plain Gmail account.
GOOGLE_IMPERSONATE_SUBJECT=jesse@yourdomain.com

# ---- Meeting link (fallback only) ----
# Used ONLY when GOOGLE_IMPERSONATE_SUBJECT is blank (non-Workspace). With
# Workspace + delegation above, leave this empty — Meet links are automatic.
MEETING_URL=

# ---- Confirmation email (Workspace only) ----
# A branded confirmation email is sent via Gmail AS the impersonated user.
# Requires the gmail.send scope added to domain-wide delegation (see SETUP.md).
# Optional: blind-copy yourself on every confirmation for a paper trail.
BOOKING_BCC=
