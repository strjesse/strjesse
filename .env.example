# =====================================================================
# Copy these into Vercel → Project → Settings → Environment Variables.
# (For local testing with `vercel dev`, copy this file to `.env` and fill
#  it in — `.env` is gitignored and must NEVER be committed.)
# =====================================================================

# ---- Stripe (use TEST keys while building: they start with sk_test_) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price of the session, in the smallest currency unit (cents). 25000 = $250.00
PRICE_CENTS=25000
CURRENCY=usd

# ---- Session timing ----
SESSION_MINUTES=90
# Timezone the booking slots are expressed in (Jesse's working tz):
BUSINESS_TIMEZONE=America/New_York
# Days off, 0=Sun..6=Sat (comma separated). Default: Sundays closed.
CLOSED_DOW=0

# ---- Google Calendar (service account) ----
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key from the JSON key file. Keep the literal \n sequences;
# in Vercel paste the real multi-line key OR keep \n — the code handles \n.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# The calendar to book into — usually Jesse's gmail address:
GOOGLE_CALENDAR_ID=jesseheight1@gmail.com

# ---- Meeting link (recommended) ----
# Your permanent Zoom or Google Meet room. Added to every confirmed event.
MEETING_URL=https://meet.google.com/your-room
